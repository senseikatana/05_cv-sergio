import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/playfair-display/700.css';
---

<!DOCTYPE html>
<html lang="es" class="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Curriculum - Sergio Jurado Casado</title>

  <meta name="description" content="CV digital e interactivo de Sergio Jurado Casado. Desarrollador Analítico & Solucionador de Problemas Logísticos.">
  <meta property="og:title" content="Sergio Jurado Casado — CV Digital">
  <meta property="og:description" content="Consultor de Operaciones & Solucionador de Problemas">
  <meta property="og:type" content="profile">
  <meta name="twitter:card" content="summary">

  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Sergio Jurado Casado",
    "jobTitle": "Consultor de Operaciones",
    "description": "Consultor de Operaciones & Solucionador de Problemas Logísticos",
    "url": "https://senseikatana.github.io",
    "email": "empleo@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Cambrils",
      "addressRegion": "Tarragona",
      "addressCountry": "ES"
    },
    "knowsLanguage": ["es", "en"],
    "hasOccupation": {
      "@type": "Occupation",
      "name": "Consultor de Operaciones",
      "occupationLocation": {
        "@type": "Country",
        "name": "ES"
      }
    }
  }
  </script>
</head>
<body>
  <slot />

  <div id="toast" class="toast">
    <svg fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
    </svg>
    <span id="toastMessage">Acción completada</span>
  </div>

  <script>
    import '../scripts/main.ts';
  </script>
</body>
</html>

---
import Base from '../../layouts/Base.astro';
import PrintHeader from '../../components/PrintHeader.astro';
import CVHero from '../../components/CVHero.astro';
import CVSection from '../../components/CVSection.astro';
import TimelineItem from '../../components/TimelineItem.astro';
import ProjectCard from '../../components/ProjectCard.astro';
---

<Base
  lang="es"
  accent="terra"
  title="Logística y Almacén · Sergio Jurado"
  description="Coordinación de almacén, control de stock y optimización de procesos de picking y expedición."
  activeVariant="logistica"
  activeLang="es"
>
  <main class="container-x py-12 sm:py-16">
    <PrintHeader
      subtitle="Operario de Logística y Gestión de Almacén"
      contactInfo="sergiojurado.casado@gmail.com · +34 637 723 747 · Terrassa, Catalunya"
    />

    <CVHero
      eyebrow="Logística y Almacén"
      title="Operario de Logística y Gestión de Almacén"
      description="Coordinación de almacén, control de stock y optimización de procesos de picking y expedición."
      location="Terrassa, Catalunya"
      email="sergiojurado.casado@gmail.com"
      phone="+34 637 723 747"
    />

    <div class="cv-grid grid gap-10 sm:gap-14 md:grid-cols-[1fr_1.9fr]">
      <!-- Columna izquierda -->
      <div class="space-y-10">
        <CVSection title="Sobre mí">
          <p class="text-[0.95rem] leading-relaxed text-ink-soft">
            Profesional de logística orientado a la eficiencia y la precisión. Experiencia en recepción de mercancía, gestión de inventario con SGA, preparación de pedidos y manejo de carretilla. Comprometido con la seguridad, el orden y los plazos de entrega.
          </p>
        </CVSection>

        <CVSection title="Habilidades">
          <ul class="flex flex-wrap gap-2">
            <li class="chip">Gestión de inventario (SGA/WMS)</li>
            <li class="chip">Picking y packing</li>
            <li class="chip">Carretilla elevadora (carné vigente)</li>
            <li class="chip">Control de stock y recuento cíclico</li>
            <li class="chip">Recepción y expedición</li>
            <li class="chip">Prevención de riesgos (PRL)</li>
            <li class="chip">Optimización de rutas internas</li>
            <li class="chip">Excel y ERP logístico</li>
          </ul>
        </CVSection>

        <CVSection title="Formación">
          <ul class="space-y-4">
            <li>
              <p class="text-[0.95rem] font-medium text-ink">Grado Medio en Actividades Comerciales</p>
              <p class="text-sm text-ink-muted">IES · 2017 — 2019</p>
            </li>
            <li>
              <p class="text-[0.95rem] font-medium text-ink">Carné de carretillero + PRL</p>
              <p class="text-sm text-ink-muted">Centro de Formación Logística · 2019</p>
            </li>
          </ul>
        </CVSection>
      </div>

      <!-- Columna derecha -->
      <div class="space-y-12">
        <CVSection title="Experiencia" avoidBreak={false} titleClass="mb-6">
          <div class="space-y-8">
            <TimelineItem
              title="Responsable de turno de almacén"
              date="2022 — Presente"
              subtitle="DistriCentro Logística"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Coordinación de un equipo de 8 operarios y planificación diaria de tareas.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Reducción del 18% en errores de preparación mediante doble verificación.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Implantación de recuento cíclico que mejoró la fiabilidad de stock al 99,2%.</span>
                </li>
              </ul>
            </TimelineItem>

            <TimelineItem
              title="Operario de almacén"
              date="2019 — 2022"
              subtitle="LogiPack Ibérica"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Preparación de más de 250 pedidos diarios con sistema de radiofrecuencia.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Manejo de carretilla frontal y retráctil en zonas de gran volumen.</span>
                </li>
              </ul>
            </TimelineItem>
          </div>
        </CVSection>

        <CVSection title="Proyectos destacados" avoidBreak={false} titleClass="mb-6">
          <div class="grid gap-4 sm:grid-cols-2">
            <ProjectCard
              href="https://github.com/senseikatana/sga-vilaseca"
              tags="WMS · Gestión de almacén"
              title="Novatecnica SGA"
              description="Sistema de gestión de almacén (WMS) en tiempo real: control de inventario multiubicación, picking por olas, recepción, conteo cíclico y dashboards de KPIs."
              linkText="Ver en GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Logística · Inventario"
              title="Warehouse Manager"
              description="Aplicación de gestión de almacén con backend y frontend: seguimiento de stock, tareas de operario y trazabilidad de movimientos entre zonas."
              linkText="Ver en GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Automatización"
              title="Snippets y utilidades de sistema"
              description="Colección de scripts de utilidades (discos, red/VPN, rescate SSH) útiles para la operativa diaria y el mantenimiento de equipos."
              linkText="Ver en GitHub"
            />
          </div>
        </CVSection>
      </div>
    </div>
  </main>
</Base>

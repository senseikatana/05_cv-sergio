---
import Base from '../../layouts/Base.astro';
import PrintHeader from '../../components/PrintHeader.astro';
import CVHero from '../../components/CVHero.astro';
import CVSection from '../../components/CVSection.astro';
import TimelineItem from '../../components/TimelineItem.astro';
import ProjectCard from '../../components/ProjectCard.astro';
---

<Base
  lang="es"
  accent="violet"
  title="Perfil Genérico · Sergio Jurado"
  description="Persona resolutiva, organizada y con ganas de aportar valor en cualquier equipo."
  activeVariant="generico"
  activeLang="es"
>
  <main class="container-x py-12 sm:py-16">
    <PrintHeader
      subtitle="Profesional polivalente · Orientado a resultados"
      contactInfo="sergiojurado.casado@gmail.com · +34 637 723 747 · Terrassa, Catalunya"
    />

    <CVHero
      eyebrow="Perfil Genérico"
      title="Profesional polivalente · Orientado a resultados"
      description="Persona resolutiva, organizada y con ganas de aportar valor en cualquier equipo."
      location="Terrassa, Catalunya"
      email="sergiojurado.casado@gmail.com"
      phone="+34 637 723 747"
    />

    <div class="cv-grid grid gap-10 sm:gap-14 md:grid-cols-[1fr_1.9fr]">
      <!-- Columna izquierda -->
      <div class="space-y-10">
        <CVSection title="Sobre mí">
          <p class="text-[0.95rem] leading-relaxed text-ink-soft">
            Profesional versátil con capacidad de adaptación, comunicación y trabajo en equipo. Combino rigor y orientación al detalle con una actitud proactiva para asumir nuevos retos y aprender rápido.
          </p>
        </CVSection>

        <CVSection title="Habilidades">
          <ul class="flex flex-wrap gap-2">
            <li class="chip">Comunicación y trabajo en equipo</li>
            <li class="chip">Organización y gestión del tiempo</li>
            <li class="chip">Resolución de problemas</li>
            <li class="chip">Atención al cliente</li>
            <li class="chip">Ofimática (Office / Google)</li>
            <li class="chip">Idiomas: Español, Catalán, Inglés (B2)</li>
            <li class="chip">Adaptabilidad</li>
            <li class="chip">Iniciativa y proactividad</li>
          </ul>
        </CVSection>

        <CVSection title="Formación">
          <ul class="space-y-4">
            <li>
              <p class="text-[0.95rem] font-medium text-ink">Grado en Administración y Dirección de Empresas</p>
              <p class="text-sm text-ink-muted">Universidad · 2014 — 2018</p>
            </li>
            <li>
              <p class="text-[0.95rem] font-medium text-ink">Curso de Gestión de Proyectos</p>
              <p class="text-sm text-ink-muted">Centro de Formación · 2020</p>
            </li>
          </ul>
        </CVSection>
      </div>

      <!-- Columna derecha -->
      <div class="space-y-12">
        <CVSection title="Experiencia" avoidBreak={false} titleClass="mb-6">
          <div class="space-y-8">
            <TimelineItem
              title="Coordinador de proyectos"
              date="2021 — Presente"
              subtitle="Empresa de servicios"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Coordinación de tareas entre departamentos y seguimiento de objetivos.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Mejora de procesos internos y reporting periódico a dirección.</span>
                </li>
              </ul>
            </TimelineItem>

            <TimelineItem
              title="Atención al cliente"
              date="2018 — 2021"
              subtitle="Comercio / Servicios"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Gestión de incidencias y soporte directo a clientes.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Reconocimiento por satisfacción del cliente y resolución eficaz.</span>
                </li>
              </ul>
            </TimelineItem>
          </div>
        </CVSection>

        <CVSection title="Proyectos destacados" avoidBreak={false} titleClass="mb-6">
          <div class="grid gap-4 sm:grid-cols-2">
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Proyecto personal"
              title="Portfolio personal"
              description="Monorepo con mi portfolio y múltiples proyectos web: tiendas, apps y plantillas. Construido con Astro y TypeScript."
              linkText="Ver en GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Contenido · Documentación"
              title="Recetas naturales"
              description="Recopilación de recetas caseras y productos naturales documentados paso a paso. Un proyecto personal de organización de conocimiento."
              linkText="Ver en GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Web · Catálogo"
              title="Num Perfumes"
              description="Proyecto web de catálogo de perfumes con Astro, orientado a una presentación cuidada de producto."
              linkText="Ver en GitHub"
            />
          </div>
        </CVSection>
      </div>
    </div>
  </main>
</Base>

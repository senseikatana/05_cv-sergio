---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ValueProposition from '../components/ValueProposition.astro';
import Skills from '../components/Skills.astro';
import Languages from '../components/Languages.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import Projects from '../components/Projects.astro';
import Certifications from '../components/Certifications.astro';
import Downloads from '../components/Downloads.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Navbar />

  <main class="main-wrapper container">
    <div class="a4-paper">
      <div class="a4-grid">

        <Hero />
        <ValueProposition />

        <div class="col-left space-y">
          <Skills />
          <Languages />
        </div>

        <div class="col-right">
          <Experience />
          <Projects />
          <Certifications />
          <Education />
          <Downloads />
          <ContactForm />

          <div class="print-only" style="border-top:1px solid #ccc;padding-top:1.5rem;margin-top:1.5rem;text-align:center;">
            <p style="font-size:0.875rem;color:#666;">
              Versión impresa. Para acceder al CV interactivo y contactarme directamente, visita: <strong>www.tu-web-personal.com</strong>
            </p>
          </div>
        </div>

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

---
import Base from '../../layouts/Base.astro';
import PrintHeader from '../../components/PrintHeader.astro';
import CVHero from '../../components/CVHero.astro';
import CVSection from '../../components/CVSection.astro';
import TimelineItem from '../../components/TimelineItem.astro';
import ProjectCard from '../../components/ProjectCard.astro';
---

<Base
  lang="ca"
  accent="terra"
  title="Logística i Magatzem · Sergio Jurado"
  description="Coordinació de magatzem, control d’estoc i optimització de processos de picking i expedició."
  activeVariant="logistica"
  activeLang="ca"
>
  <main class="container-x py-12 sm:py-16">
    <PrintHeader
      subtitle="Operari de Logística i Gestió de Magatzem"
      contactInfo="sergiojurado.casado@gmail.com · +34 637 723 747 · Terrassa, Catalunya"
    />

    <CVHero
      eyebrow="Logística i Magatzem"
      title="Operari de Logística i Gestió de Magatzem"
      description="Coordinació de magatzem, control d’estoc i optimització de processos de picking i expedició."
      location="Terrassa, Catalunya"
      email="sergiojurado.casado@gmail.com"
      phone="+34 637 723 747"
    />

    <div class="cv-grid grid gap-10 sm:gap-14 md:grid-cols-[1fr_1.9fr]">
      <!-- Columna izquierda -->
      <div class="space-y-10">
        <CVSection title="Sobre mi">
          <p class="text-[0.95rem] leading-relaxed text-ink-soft">
            Professional de logística orientat a l’eficiència i la precisió. Experiència en recepció de mercaderia, gestió d’inventari amb SGA, preparació de comandes i maneig de carretó. Compromès amb la seguretat, l’ordre i els terminis de lliurament.
          </p>
        </CVSection>

        <CVSection title="Habilitats">
          <ul class="flex flex-wrap gap-2">
            <li class="chip">Gestió d’inventari (SGA/WMS)</li>
            <li class="chip">Picking i packing</li>
            <li class="chip">Carretó elevador (carnet vigent)</li>
            <li class="chip">Control d’estoc i recompte cíclic</li>
            <li class="chip">Recepció i expedició</li>
            <li class="chip">Prevenció de riscos (PRL)</li>
            <li class="chip">Optimització de rutes internes</li>
            <li class="chip">Excel i ERP logístic</li>
          </ul>
        </CVSection>

        <CVSection title="Formació">
          <ul class="space-y-4">
            <li>
              <p class="text-[0.95rem] font-medium text-ink">Grau Mitjà en Activitats Comercials</p>
              <p class="text-sm text-ink-muted">IES · 2017 — 2019</p>
            </li>
            <li>
              <p class="text-[0.95rem] font-medium text-ink">Carnet de carretoner + PRL</p>
              <p class="text-sm text-ink-muted">Centre de Formació Logística · 2019</p>
            </li>
          </ul>
        </CVSection>
      </div>

      <!-- Columna derecha -->
      <div class="space-y-12">
        <CVSection title="Experiència" avoidBreak={false} titleClass="mb-6">
          <div class="space-y-8">
            <TimelineItem
              title="Responsable de torn de magatzem"
              date="2022 — Actualitat"
              subtitle="DistriCentro Logística"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Coordinació d’un equip de 8 operaris i planificació diària de tasques.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Reducció del 18% en errors de preparació mitjançant doble verificació.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Implantació de recompte cíclic que va millorar la fiabilitat d’estoc al 99,2%.</span>
                </li>
              </ul>
            </TimelineItem>

            <TimelineItem
              title="Operari de magatzem"
              date="2019 — 2022"
              subtitle="LogiPack Ibérica"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Preparació de més de 250 comandes diàries amb sistema de radiofreqüència.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Maneig de carretó frontal i retràctil en zones de gran volum.</span>
                </li>
              </ul>
            </TimelineItem>
          </div>
        </CVSection>

        <CVSection title="Projectes destacats" avoidBreak={false} titleClass="mb-6">
          <div class="grid gap-4 sm:grid-cols-2">
            <ProjectCard
              href="https://github.com/senseikatana/sga-vilaseca"
              tags="WMS · Gestió de magatzem"
              title="Novatecnica SGA"
              description="Sistema de gestió de magatzem (WMS) en temps real: control d’inventari multiubicació, picking per onades, recepció, recompte cíclic i dashboards de KPIs."
              linkText="Veure a GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Logística · Inventari"
              title="Warehouse Manager"
              description="Aplicació de gestió de magatzem amb backend i frontend: seguiment d’estoc, tasques d’operari i traçabilitat de moviments entre zones."
              linkText="Veure a GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Automatització"
              title="Snippets i utilitats de sistema"
              description="Col·lecció de scripts d’utilitats (discos, xarxa/VPN, rescat SSH) útils per a l’operativa diària i el manteniment d’equips."
              linkText="Veure a GitHub"
            />
          </div>
        </CVSection>
      </div>
    </div>
  </main>
</Base>

---
import Base from '../../layouts/Base.astro';
import PrintHeader from '../../components/PrintHeader.astro';
import CVHero from '../../components/CVHero.astro';
import CVSection from '../../components/CVSection.astro';
import TimelineItem from '../../components/TimelineItem.astro';
import ProjectCard from '../../components/ProjectCard.astro';
---

<Base
  lang="ca"
  accent="teal"
  title="Fullstack i Creatiu Digital · Sergio Jurado"
  description="Construeixo productes web ràpids i bonics, del concepte al desplegament, cuidant el detall visual."
  activeVariant="fullstack"
  activeLang="ca"
>
  <main class="container-x py-12 sm:py-16">
    <PrintHeader
      subtitle="Desenvolupador Fullstack · Disseny Creatiu Digital"
      contactInfo="sergiojurado.casado@gmail.com · +34 637 723 747 · Terrassa, Catalunya"
    />

    <CVHero
      eyebrow="Fullstack i Creatiu Digital"
      title="Desenvolupador Fullstack · Disseny Creatiu Digital"
      description="Construeixo productes web ràpids i bonics, del concepte al desplegament, cuidant el detall visual."
      location="Terrassa, Catalunya"
      email="sergiojurado.casado@gmail.com"
      phone="+34 637 723 747"
    />

    <div class="cv-grid grid gap-10 sm:gap-14 md:grid-cols-[1fr_1.9fr]">
      <!-- Columna izquierda -->
      <div class="space-y-10">
        <CVSection title="Sobre mi">
          <p class="text-[0.95rem] leading-relaxed text-ink-soft">
            Desenvolupador fullstack amb sensibilitat de disseny. Treballo amb JavaScript/TypeScript al frontend i backend, i gaudeixo convertint idees en interfícies netes i experiències cuidades. Em moc entre el codi, la tipografia i el motion.
          </p>
        </CVSection>

        <CVSection title="Habilitats">
          <ul class="flex flex-wrap gap-2">
            <li class="chip">JavaScript / TypeScript</li>
            <li class="chip">React · Astro · Next.js</li>
            <li class="chip">Node.js · Express</li>
            <li class="chip">Tailwind CSS · CSS modern</li>
            <li class="chip">PostgreSQL · MongoDB</li>
            <li class="chip">Figma · UI/UX</li>
            <li class="chip">Motion / animació web</li>
            <li class="chip">Git · CI/CD · Vercel</li>
          </ul>
        </CVSection>

        <CVSection title="Formació">
          <ul class="space-y-4">
            <li>
              <p class="text-[0.95rem] font-medium text-ink">Grau en Enginyeria Informàtica</p>
              <p class="text-sm text-ink-muted">Universitat · 2016 — 2020</p>
            </li>
            <li>
              <p class="text-[0.95rem] font-medium text-ink">Especialització en UI/UX Design</p>
              <p class="text-sm text-ink-muted">Domestika / Coursera · 2021</p>
            </li>
          </ul>
        </CVSection>
      </div>

      <!-- Columna derecha -->
      <div class="space-y-12">
        <CVSection title="Experiència" avoidBreak={false} titleClass="mb-6">
          <div class="space-y-8">
            <TimelineItem
              title="Desenvolupador Fullstack"
              date="2022 — Actualitat"
              subtitle="Estudi Pixel & Code"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Desenvolupament d’aplicacions web amb React, Astro i Node des del disseny al desplegament.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Millora del rendiment (LCP &lt; 1,5s) i accessibilitat en projectes client.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Disseny de sistemes de components reutilitzables i guies d’estil.</span>
                </li>
              </ul>
            </TimelineItem>

            <TimelineItem
              title="Frontend i Dissenyador Digital"
              date="2020 — 2022"
              subtitle="Freelance"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Landing pages, portfolios i botigues per a petites marques.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Identitat visual, tipografia i animacions de scroll.</span>
                </li>
              </ul>
            </TimelineItem>
          </div>
        </CVSection>

        <CVSection title="Projectes destacats" avoidBreak={false} titleClass="mb-6">
          <div class="grid gap-4 sm:grid-cols-2">
            <ProjectCard
              href="https://github.com/senseikatana/sga-vilaseca"
              tags="React · TS · Hono · Bun"
              title="Novatecnica SGA"
              description="WMS fullstack amb React, TypeScript, Hono i Bun. Control d’inventari en temps real, picking per onades, escaneig de codis i panell amb mètriques."
              linkText="Veure a GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Astro · E-commerce"
              title="Treslunas Boutique"
              description="Botiga online construïda amb Astro i base de dades integrada. Catàleg, disseny cuidat i enfocament en rendiment."
              linkText="Veure a GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="UI · HTML/CSS"
              title="Digital Bank App"
              description="Interfície d’aplicació bancària digital amb HTML i CSS, centrada en una UI neta i una experiència clara."
              linkText="Veure a GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="TypeScript · Vite"
              title="Coffeeshop"
              description="App web de cafeteria amb TypeScript i Vite. Interfície moderna i components reutilitzables."
              linkText="Veure a GitHub"
            />
          </div>
        </CVSection>
      </div>
    </div>
  </main>
</Base>

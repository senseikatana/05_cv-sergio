---
import Base from '../../layouts/Base.astro';
import PrintHeader from '../../components/PrintHeader.astro';
import CVHero from '../../components/CVHero.astro';
import CVSection from '../../components/CVSection.astro';
import TimelineItem from '../../components/TimelineItem.astro';
import ProjectCard from '../../components/ProjectCard.astro';
---

<Base
  lang="en"
  accent="terra"
  title="Logistics & Warehouse · Sergio Jurado"
  description="Warehouse coordination, stock control and optimisation of picking and dispatch processes."
  activeVariant="logistica"
  activeLang="en"
>
  <main class="container-x py-12 sm:py-16">
    <PrintHeader
      subtitle="Logistics Operator & Warehouse Management"
      contactInfo="sergiojurado.casado@gmail.com · +34 637 723 747 · Terrassa, Catalonia"
    />

    <CVHero
      eyebrow="Logistics & Warehouse"
      title="Logistics Operator & Warehouse Management"
      description="Warehouse coordination, stock control and optimisation of picking and dispatch processes."
      location="Terrassa, Catalonia"
      email="sergiojurado.casado@gmail.com"
      phone="+34 637 723 747"
    />

    <div class="cv-grid grid gap-10 sm:gap-14 md:grid-cols-[1fr_1.9fr]">
      <!-- Columna izquierda -->
      <div class="space-y-10">
        <CVSection title="About me">
          <p class="text-[0.95rem] leading-relaxed text-ink-soft">
            Logistics professional focused on efficiency and accuracy. Experienced in goods receiving, inventory management with WMS, order picking and forklift operation. Committed to safety, order and delivery deadlines.
          </p>
        </CVSection>

        <CVSection title="Skills">
          <ul class="flex flex-wrap gap-2">
            <li class="chip">Inventory management (WMS)</li>
            <li class="chip">Picking & packing</li>
            <li class="chip">Forklift (valid licence)</li>
            <li class="chip">Stock control & cycle counting</li>
            <li class="chip">Receiving & dispatch</li>
            <li class="chip">Risk prevention (PRL)</li>
            <li class="chip">Internal route optimisation</li>
            <li class="chip">Excel & logistics ERP</li>
          </ul>
        </CVSection>

        <CVSection title="Education">
          <ul class="space-y-4">
            <li>
              <p class="text-[0.95rem] font-medium text-ink">Vocational Diploma in Commercial Activities</p>
              <p class="text-sm text-ink-muted">IES · 2017 — 2019</p>
            </li>
            <li>
              <p class="text-[0.95rem] font-medium text-ink">Forklift licence + safety (PRL)</p>
              <p class="text-sm text-ink-muted">Logistics Training Centre · 2019</p>
            </li>
          </ul>
        </CVSection>
      </div>

      <!-- Columna derecha -->
      <div class="space-y-12">
        <CVSection title="Experience" avoidBreak={false} titleClass="mb-6">
          <div class="space-y-8">
            <TimelineItem
              title="Warehouse Shift Lead"
              date="2022 — Present"
              subtitle="DistriCentro Logística"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Coordinated a team of 8 operators and planned daily tasks.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Reduced picking errors by 18% through double-verification.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Implemented cycle counting that improved stock accuracy to 99.2%.</span>
                </li>
              </ul>
            </TimelineItem>

            <TimelineItem
              title="Warehouse Operator"
              date="2019 — 2022"
              subtitle="LogiPack Ibérica"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Prepared 250+ daily orders using a radio-frequency system.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Operated front and reach forklifts in high-volume areas.</span>
                </li>
              </ul>
            </TimelineItem>
          </div>
        </CVSection>

        <CVSection title="Featured projects" avoidBreak={false} titleClass="mb-6">
          <div class="grid gap-4 sm:grid-cols-2">
            <ProjectCard
              href="https://github.com/senseikatana/sga-vilaseca"
              tags="WMS · Warehouse mgmt"
              title="Novatecnica WMS"
              description="Real-time warehouse management system (WMS): multi-location inventory control, wave picking, receiving, cycle counting and KPI dashboards."
              linkText="View on GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Logistics · Inventory"
              title="Warehouse Manager"
              description="Warehouse management app with backend and frontend: stock tracking, operator tasks and traceability of movements between zones."
              linkText="View on GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Automation"
              title="System snippets & utilities"
              description="A collection of utility scripts (disks, network/VPN, SSH rescue) useful for daily operations and equipment maintenance."
              linkText="View on GitHub"
            />
          </div>
        </CVSection>
      </div>
    </div>
  </main>
</Base>

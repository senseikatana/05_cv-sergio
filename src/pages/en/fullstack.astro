---
import Base from '../../layouts/Base.astro';
import PrintHeader from '../../components/PrintHeader.astro';
import CVHero from '../../components/CVHero.astro';
import CVSection from '../../components/CVSection.astro';
import TimelineItem from '../../components/TimelineItem.astro';
import ProjectCard from '../../components/ProjectCard.astro';
---

<Base
  lang="en"
  accent="teal"
  title="Fullstack & Digital Creative · Sergio Jurado"
  description="I build fast, beautiful web products from concept to deployment, with care for visual detail."
  activeVariant="fullstack"
  activeLang="en"
>
  <main class="container-x py-12 sm:py-16">
    <PrintHeader
      subtitle="Fullstack Developer · Digital Creative Design"
      contactInfo="sergiojurado.casado@gmail.com · +34 637 723 747 · Terrassa, Catalonia"
    />

    <CVHero
      eyebrow="Fullstack & Digital Creative"
      title="Fullstack Developer · Digital Creative Design"
      description="I build fast, beautiful web products from concept to deployment, with care for visual detail."
      location="Terrassa, Catalonia"
      email="sergiojurado.casado@gmail.com"
      phone="+34 637 723 747"
    />

    <div class="cv-grid grid gap-10 sm:gap-14 md:grid-cols-[1fr_1.9fr]">
      <!-- Columna izquierda -->
      <div class="space-y-10">
        <CVSection title="About me">
          <p class="text-[0.95rem] leading-relaxed text-ink-soft">
            Fullstack developer with a designer’s eye. I work with JavaScript/TypeScript on the frontend and backend, and enjoy turning ideas into clean interfaces and polished experiences. I move between code, typography and motion.
          </p>
        </CVSection>

        <CVSection title="Skills">
          <ul class="flex flex-wrap gap-2">
            <li class="chip">JavaScript / TypeScript</li>
            <li class="chip">React · Astro · Next.js</li>
            <li class="chip">Node.js · Express</li>
            <li class="chip">Tailwind CSS · modern CSS</li>
            <li class="chip">PostgreSQL · MongoDB</li>
            <li class="chip">Figma · UI/UX</li>
            <li class="chip">Motion / web animation</li>
            <li class="chip">Git · CI/CD · Vercel</li>
          </ul>
        </CVSection>

        <CVSection title="Education">
          <ul class="space-y-4">
            <li>
              <p class="text-[0.95rem] font-medium text-ink">BSc in Computer Engineering</p>
              <p class="text-sm text-ink-muted">University · 2016 — 2020</p>
            </li>
            <li>
              <p class="text-[0.95rem] font-medium text-ink">UI/UX Design specialisation</p>
              <p class="text-sm text-ink-muted">Domestika / Coursera · 2021</p>
            </li>
          </ul>
        </CVSection>
      </div>

      <!-- Columna derecha -->
      <div class="space-y-12">
        <CVSection title="Experience" avoidBreak={false} titleClass="mb-6">
          <div class="space-y-8">
            <TimelineItem
              title="Fullstack Developer"
              date="2022 — Present"
              subtitle="Estudio Pixel & Code"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Built web applications with React, Astro and Node from design to deployment.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Improved performance (LCP &lt; 1.5s) and accessibility on client projects.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Designed reusable component systems and style guides.</span>
                </li>
              </ul>
            </TimelineItem>

            <TimelineItem
              title="Frontend & Digital Designer"
              date="2020 — 2022"
              subtitle="Freelance"
            >
              <ul class="mt-3 space-y-1.5">
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Landing pages, portfolios and shops for small brands.</span>
                </li>
                <li class="flex gap-2.5 text-[0.92rem] leading-relaxed text-ink-soft">
                  <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent-soft"></span>
                  <span>Visual identity, typography and scroll animations.</span>
                </li>
              </ul>
            </TimelineItem>
          </div>
        </CVSection>

        <CVSection title="Featured projects" avoidBreak={false} titleClass="mb-6">
          <div class="grid gap-4 sm:grid-cols-2">
            <ProjectCard
              href="https://github.com/senseikatana/sga-vilaseca"
              tags="React · TS · Hono · Bun"
              title="Novatecnica WMS"
              description="Fullstack WMS with React, TypeScript, Hono and Bun. Real-time inventory control, wave picking, barcode scanning and a metrics dashboard."
              linkText="View on GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="Astro · E-commerce"
              title="Treslunas Boutique"
              description="Online shop built with Astro and an integrated database. Catalogue, careful design and a focus on performance."
              linkText="View on GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="UI · HTML/CSS"
              title="Digital Bank App"
              description="Digital banking app interface with HTML and CSS, focused on a clean UI and a clear experience."
              linkText="View on GitHub"
            />
            <ProjectCard
              href="https://github.com/senseikatana"
              tags="TypeScript · Vite"
              title="Coffeeshop"
              description="Coffee-shop web app with TypeScript and Vite. Modern interface and reusable components."
              linkText="View on GitHub"
            />
          </div>
        </CVSection>
      </div>
    </div>
  </main>
</Base>

---
interface Props {
  title: string;
  date: string;
  subtitle: string;
}

const { title, date, subtitle } = Astro.props;
---
<article class="avoid-break border-l-2 border-line pl-5">
  <div class="flex flex-wrap items-baseline justify-between gap-x-4">
    <h3 class="font-display text-xl">{title}</h3>
    <span class="text-sm text-ink-muted">{date}</span>
  </div>
  <p class="mt-0.5 text-sm font-medium text-accent">{subtitle}</p>
  <slot />
</article>

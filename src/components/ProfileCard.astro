---
interface Props {
  href: string;
  accent: 'terra' | 'teal' | 'violet';
  title: string;
  description: string;
  linkText: string;
}

const { href, accent, title, description, linkText } = Astro.props;
---
<a href={href} data-accent={accent} class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper-card p-7 transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:shadow-[0_18px_40px_-22px_rgba(0,0,0,0.35)]">
  <span class="absolute inset-x-0 top-0 h-[3px] origin-left scale-x-0 bg-gradient-to-r from-accent to-accent-soft transition-transform duration-300 group-hover:scale-x-100"></span>
  <span class="inline-block h-10 w-10 rounded-full border-[1.5px] border-accent bg-accent/10"></span>
  <h3 class="mt-5 font-display text-2xl leading-tight">{title}</h3>
  <p class="mt-3 flex-1 text-[0.95rem] leading-relaxed text-ink-soft">{description}</p>
  <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-accent">
    {linkText} <span class="transition-transform group-hover:translate-x-1">→</span>
  </span>
</a>

---
import { downloads } from '../data/index';
---

<div class="section-fade no-print">
  <h2 class="h2-section" style="margin-bottom:var(--space-4);margin-top:var(--space-8);" data-i18n="docs.title">Documentos Adjuntos</h2>
  <div class="bento-grid">
    {downloads.map((d) => (
      <a href="#" class="bento-item dynamic-download" data-filename={d.filename} data-content={d.content}>
        <div class={`bento-icon icon-${d.icon}`}>
          <svg fill={d.svgType === 'fill' ? 'currentColor' : 'none'} stroke={d.svgType === 'stroke' ? 'currentColor' : ''} viewBox="0 0 24 24" style="width:24px;height:24px;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width={d.svgType === 'stroke' ? '2' : ''} d={d.svgPath} />
          </svg>
        </div>
        <span style="font-size:var(--text-sm);font-weight:700;">{d.title}</span>
        <span style="font-size:var(--text-xs);color:var(--color-primary);margin-top:0.25rem;">Descargar</span>
      </a>
    ))}
  </div>
</div>

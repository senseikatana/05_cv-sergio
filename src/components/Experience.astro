---
import { experiences } from '../data/index';
---

<div class="section-fade">
  <h2 class="h2-section" data-i18n="experience.title">Trayectoria Profesional</h2>
  <div class="timeline">
    {experiences.map((e) => (
      <div class="timeline-item">
        <div class="timeline-dot" style={e.active ? '' : 'border-color:var(--color-text-muted);'}></div>
        <div class="timeline-header">
          <h3 class="h3-title" data-i18n={e.roleI18n}>{e.role}</h3>
          <span class="timeline-date" style={e.active ? '' : 'background:transparent;color:var(--color-text-muted);'}>{e.date}</span>
        </div>
        <p class="timeline-company">{e.company}</p>
        <p class="timeline-desc" data-i18n={e.descI18n}>{e.desc}</p>
      </div>
    ))}
  </div>
</div>

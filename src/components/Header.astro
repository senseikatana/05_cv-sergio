---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;
const isHome = currentPage === 'home';
---

<header class="site-header no-print sticky top-0 z-50 border-b border-line bg-paper/80 backdrop-blur-md backdrop-saturate-150">
  <div class="container-x flex h-16 items-center justify-between gap-4">
    {/* Left side: Logo (only shown on subpages) */}
    {!isHome ? (
      <a href="/" class="flex items-center gap-2.5" aria-label="Inicio">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <rect width="32" height="32" rx="7" class="fill-ink"></rect>
          <path d="M10 22V10h5.2c2.6 0 4.3 1.4 4.3 3.6 0 1.6-.9 2.7-2.3 3.1L20 22h-2.6l-2.4-4.6H12V22h-2zm2-6.3h2.9c1.3 0 2.1-.6 2.1-1.8s-.8-1.8-2.1-1.8H12v3.6z" class="fill-paper"></path>
        </svg>
        <span class="font-display text-lg tracking-tight">Sergio Jurado</span>
      </a>
    ) : null}

    {/* Navigation Links */}
    <nav class={isHome ? "flex items-center gap-7 text-sm text-ink-soft" : "hidden items-center gap-7 text-sm text-ink-soft md:flex"}>
      <a href="/" class={`link-underline transition-colors hover:text-ink ${currentPage === 'home' ? 'font-medium text-ink' : ''}`} aria-current={currentPage === 'home' ? 'page' : undefined}>Inicio</a>
      <a href="/es/logistica" class={`link-underline transition-colors hover:text-ink ${currentPage === 'logistica' ? 'font-medium text-ink' : ''}`} aria-current={currentPage === 'logistica' ? 'page' : undefined}>Logística</a>
      <a href="/es/fullstack" class={`link-underline transition-colors hover:text-ink ${currentPage === 'fullstack' ? 'font-medium text-ink' : ''}`} aria-current={currentPage === 'fullstack' ? 'page' : undefined}>Fullstack</a>
      <a href="/es/generico" class={`link-underline transition-colors hover:text-ink ${currentPage === 'generico' ? 'font-medium text-ink' : ''}`} aria-current={currentPage === 'generico' ? 'page' : undefined}>Genérico</a>
    </nav>

    {/* Right Controls */}
    <div class="flex items-center gap-3">
      {!isHome && (
        <div class="hidden sm:block">
          <div class="no-print flex items-center gap-1 text-[0.78rem]">
            <a href="/" hreflang="es" class="px-1 uppercase tracking-wide transition-colors hover:text-accent text-ink-muted">es</a>
          </div>
        </div>
      )}
      <ThemeToggle />
      <button onclick="window.print()" class="hidden rounded-full bg-ink px-4 py-1.5 text-sm text-paper transition-all hover:opacity-85 sm:inline-block">Imprimir</button>
      <button id="menu-toggle" type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-soft md:hidden" aria-label="Menú" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile Menu */}
  <div id="mobile-menu" class="hidden border-t border-line bg-paper md:hidden">
    <nav class="container-x flex flex-col gap-1 py-4 text-base">
      <a href="/" class={`rounded-lg px-3 py-2 transition-colors hover:bg-paper-card ${currentPage === 'home' ? 'font-medium text-accent' : 'text-ink-soft'}`}>Inicio</a>
      <a href="/es/logistica" class={`rounded-lg px-3 py-2 transition-colors hover:bg-paper-card ${currentPage === 'logistica' ? 'font-medium text-accent' : 'text-ink-soft'}`}>Logística</a>
      <a href="/es/fullstack" class={`rounded-lg px-3 py-2 transition-colors hover:bg-paper-card ${currentPage === 'fullstack' ? 'font-medium text-accent' : 'text-ink-soft'}`}>Fullstack</a>
      <a href="/es/generico" class={`rounded-lg px-3 py-2 transition-colors hover:bg-paper-card ${currentPage === 'generico' ? 'font-medium text-accent' : 'text-ink-soft'}`}>Genérico</a>
      <div class="mt-3 flex items-center justify-between border-t border-line px-3 pt-4">
        {!isHome && (
          <div class="no-print flex items-center gap-1 text-[0.78rem]">
            <a href="/" hreflang="es" class="px-1 uppercase tracking-wide transition-colors hover:text-accent text-ink-muted">es</a>
          </div>
        )}
        <button onclick="window.print()" class="rounded-full bg-ink px-4 py-1.5 text-sm text-paper">Imprimir</button>
      </div>
    </nav>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  
  menuToggle?.addEventListener("click", () => {
    const isHidden = mobileMenu?.classList.toggle("hidden");
    menuToggle.setAttribute("aria-expanded", String(!isHidden));
  });
</script>

---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  location: string;
  email: string;
  phone: string;
}

const { eyebrow, title, description, location, email, phone } = Astro.props;
---
<section class="reveal mb-12 sm:mb-16">
  <p class="eyebrow">{eyebrow}</p>
  <h1 class="mt-3 text-hero text-[clamp(2.25rem,7vw,4.5rem)] leading-[1.02]">{title}</h1>
  <p class="mt-5 max-w-prose text-base leading-relaxed text-ink-soft sm:text-lg">{description}</p>
  <div class="no-print mt-7 flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-muted">
    <span>{location}</span>
    <a href={`mailto:${email}`} class="link-underline">{email}</a>
    <span>{phone}</span>
  </div>
</section>

<header class="navbar no-print">
  <div class="navbar-content">
    <div class="nav-controls">
      <div class="dropdown">
        <button class="btn-icon" id="btnLang" onclick="document.getElementById('menuLang').classList.toggle('show')">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
          </svg>
          <span id="txtLang" class="lang-label">ES</span>
        </button>
        <div class="dropdown-menu" id="menuLang">
          <button class="dropdown-item active" onclick="window.switchLang('es')">Español</button>
          <button class="dropdown-item" onclick="window.switchLang('en')">English</button>
        </div>
      </div>

      <button class="btn-icon" id="btnTheme" onclick="window.toggleTheme()" title="Cambiar tema">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" id="themeIcon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </div>
  </div>
</header>

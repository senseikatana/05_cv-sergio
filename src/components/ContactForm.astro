<div class="contact-box section-fade interactive-only no-print">
  <h2 class="h3-title">¿Conectamos?</h2>
  <p style="font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--space-6);">Si mi propuesta encaja con los retos de tu equipo, envíame tu oferta directamente.</p>

  <form id="contactForm" action="https://formspree.io/f/tu-endpoint" method="POST">

    <div class="dropzone" id="dropzone">
      <input type="file" id="fileInput" class="hidden" accept=".pdf,.doc,.docx">
      <div style="display:inline-flex;padding:var(--space-2);background:var(--color-bg-body);border-radius:50%;margin-bottom:var(--space-2);color:var(--color-primary);">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="width:24px;height:24px;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
        </svg>
      </div>
      <p style="font-size:var(--text-sm);font-weight:500;">Arrastra una oferta en PDF aquí</p>
      <p style="font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--space-1);">o haz clic para explorar tus archivos</p>
      <p id="fileNameDisplay" class="hidden" style="margin-top:var(--space-4);font-size:var(--text-xs);font-weight:bold;color:var(--color-primary);"></p>
    </div>

    <div class="form-row">
      <input type="email" name="email" required placeholder="Tu correo corporativo" class="input-text">
      <button type="submit" class="btn btn-primary">Enviar Contacto</button>
    </div>
  </form>
</div>

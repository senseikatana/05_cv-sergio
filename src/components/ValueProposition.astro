---
import { pilares, busco, ofrezco } from '../data/index';
---

<div class="cycle-wrapper section-fade">
  <div class="cycle-container">

    <div class="connector-line"></div>
    <svg class="connector-arrow right" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <svg class="connector-arrow left" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>

    <div class="cycle-box" style="border-color: rgba(14, 165, 233, 0.3);">
      <div class="cycle-icon cycle-icon-left">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
      <h3 class="h3-title" data-i18n="busco.title">Busco...</h3>
      <ul class="cycle-list">
        {busco.map((b) => (
          <li data-i18n={b.i18nKey}>{b.text}</li>
        ))}
      </ul>
    </div>

    <div class="cycle-center">
      <div class="avatar-container">
        <figure>
          <img src="/images/avatar.gif" alt="Foto perfil de Sergio Jurado" class="avatar-image">
        </figure>
      </div>
      <div class="text-center" style="padding:0 10px;">
        <p style="font-size:var(--text-xs);font-weight:700;color:var(--color-primary);text-transform:uppercase;margin-bottom:4px;">Pilares Centrales</p>
        <p style="font-size:var(--text-xs);color:var(--color-text-muted);font-weight:500;">
          {pilares.map((p, i) => (
            <>{i > 0 && ' + '}<span data-i18n={p.label}>{p.name}</span></>
          ))}
        </p>
      </div>
    </div>

    <div class="cycle-box" style="border-color: rgba(34, 197, 94, 0.3);">
      <div class="cycle-icon cycle-icon-right">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
        </svg>
      </div>
      <h3 class="h3-title" style="text-align:right;" data-i18n="ofrezco.title">Ofrezco...</h3>
      <ul class="cycle-list">
        {ofrezco.map((o) => (
          <li data-i18n={o.i18nKey}>{o.text}</li>
        ))}
      </ul>
    </div>

  </div>
</div>

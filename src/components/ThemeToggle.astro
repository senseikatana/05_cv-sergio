---
<button id="theme-toggle" type="button" class="no-print inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink-soft transition-colors hover:border-accent hover:text-accent" aria-label="Cambiar tema" title="Cambiar tema">
  <!-- Sun Icon (visible in dark mode) -->
  <svg class="hidden h-[18px] w-[18px] dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"></path>
  </svg>
  <!-- Moon Icon (visible in light mode) -->
  <svg class="block h-[18px] w-[18px] dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
  </svg>
</button>

<script>
  const themeToggle = document.getElementById("theme-toggle");
  
  function isDark() {
    return document.documentElement.classList.contains("dark");
  }

  themeToggle?.addEventListener("click", () => {
    const nextTheme = isDark() ? "light" : "dark";
    document.documentElement.classList.toggle("dark", nextTheme === "dark");
    try {
      localStorage.setItem("theme", nextTheme);
    } catch (e) {}
  });
</script>

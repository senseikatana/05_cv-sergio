---
interface Props {
  href: string;
  tags: string;
  title: string;
  description: string;
  linkText: string;
}

const { href, tags, title, description, linkText } = Astro.props;
---
<a href={href} target="_blank" rel="noopener noreferrer" class="card avoid-break group block rounded-xl border border-line bg-paper-card p-5 transition-all hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-sm">
  <span class="text-[0.7rem] uppercase tracking-wider text-accent">{tags}</span>
  <h3 class="mt-2 font-display text-lg leading-snug">{title}</h3>
  <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">{description}</p>
  <span class="no-print mt-3 inline-flex items-center gap-1.5 text-[0.78rem] font-medium text-ink-soft transition-colors group-hover:text-accent">
    <svg class="h-[13px] w-[13px]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-1.7c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5A11.5 11.5 0 0 0 23.5 12C23.5 5.7 18.3.5 12 .5z"></path>
    </svg>
    {linkText}
  </span>
</a>

---
import { projects } from '../data/index';
---

<div class="section-fade">
  <h2 class="h2-section" data-i18n="projects.title">Proyectos Destacados</h2>
  <div class="projects-grid">
    {projects.map((p) => (
      <div class="project-card">
        <h4 class="project-name" data-i18n={p.nameI18n}>{p.name}</h4>
        <p class="project-desc" data-i18n={p.descriptionI18n}>{p.description}</p>
        <div class="project-tags">
          {p.tags.map((tag) => (
            <span class="badge">{tag}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

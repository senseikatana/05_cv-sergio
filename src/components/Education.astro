---
import { educations } from '../data/index';
---

<div class="section-fade">
  <h2 class="h2-section" style="margin-bottom:var(--space-4);" data-i18n="about.education">Formación</h2>
  {educations.map((e) => (
    <div class="info-box">
      <div>
        <h4 style="font-weight:700;font-size:var(--text-sm);" data-i18n={e.degreeI18n}>{e.degree}</h4>
        <p style="font-size:var(--text-sm);color:var(--color-text-muted);">{e.school}</p>
      </div>
      <span style="font-size:var(--text-xs);font-weight:500;color:var(--color-text-muted);">{e.date}</span>
    </div>
  ))}
</div>

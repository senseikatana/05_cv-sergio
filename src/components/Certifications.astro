---
import { certifications } from '../data/index';
---

<div class="section-fade">
  <h2 class="h2-section" style="margin-bottom:var(--space-4);" data-i18n="certs.title">Certificaciones</h2>
  {certifications.map((c) => (
    <div class="info-box">
      <div>
        <h4 style="font-weight:700;font-size:var(--text-sm);" data-i18n={c.nameI18n}>{c.name}</h4>
        <p style="font-size:var(--text-sm);color:var(--color-text-muted);">{c.issuer}</p>
      </div>
      <span style="font-size:var(--text-xs);font-weight:500;color:var(--color-text-muted);">{c.date}</span>
    </div>
  ))}
</div>
